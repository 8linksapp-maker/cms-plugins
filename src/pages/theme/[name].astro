---
import DashLayout from '../../layouts/DashLayout.astro';
import Icon from '../../components/Icon.astro';
import { getTheme, getThemeNames, getTemplatePaths, getAllPlugins } from '../../lib/data';

export function getStaticPaths() {
  return getThemeNames().map(name => ({ params: { name } }));
}

const { name } = Astro.params;
const theme = getTheme(name);
const paths = getTemplatePaths(name);
const plugins = getAllPlugins();

const slotLabels: Record<string, string> = {
  'head':        'head',
  'body-end':    'body-end',
  'post-bottom': 'post-bottom',
  'post-after':  'post-after',
  'post-schema': 'post-schema',
};

const pluginsWithSlots = Object.entries(paths).filter(([, v]) => v.slots?.length > 0);
const totalFiles = Object.values(paths).reduce((acc, v) => acc + v.files.length + v.adminPages.length, 0);
---

<DashLayout title={`Tema ${theme.label}`} activeSection={`theme-${name}`}>
  <div class="p-8">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-slate-400 mb-6">
      <a href="/" class="hover:text-violet-600 transition-colors">Dashboard</a>
      <Icon name="ChevronRight" class="w-3.5 h-3.5" />
      <span class="text-slate-700 font-medium">Tema {theme.label}</span>
    </div>

    <!-- Header -->
    <div class="flex items-start gap-5 mb-8">
      <div class="w-16 h-16 bg-violet-600 rounded-2xl flex items-center justify-center shrink-0">
        <span class="text-2xl font-black text-white">{theme.label.charAt(0).toUpperCase()}</span>
      </div>
      <div class="flex-1">
        <div class="flex items-center gap-3">
          <h1 class="text-2xl font-bold text-slate-900">{theme.label}</h1>
          <span class="text-xs font-bold bg-violet-100 text-violet-700 px-2.5 py-1 rounded-full">{theme.status}</span>
        </div>
        <p class="text-slate-500 mt-1">{theme.description}</p>
        <p class="text-xs text-slate-400 mt-1 font-mono">templates/{name}/paths.json</p>
      </div>
      <a href="/" class="flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-violet-600 transition-colors shrink-0">
        <Icon name="ArrowLeft" class="w-4 h-4" />
        Voltar
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-3 gap-4 mb-8">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 text-center">
        <p class="text-2xl font-bold text-slate-900">{Object.keys(paths).length}</p>
        <p class="text-xs text-slate-500 mt-1">Plugins mapeados</p>
      </div>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 text-center">
        <p class="text-2xl font-bold text-slate-900">{totalFiles}</p>
        <p class="text-xs text-slate-500 mt-1">Arquivos com dest</p>
      </div>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 text-center">
        <p class="text-2xl font-bold text-slate-900">{pluginsWithSlots.length}</p>
        <p class="text-xs text-slate-500 mt-1">Com slots ativos</p>
      </div>
    </div>

    <!-- Slot map -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-6">
      <div class="flex items-center gap-2 mb-5">
        <Icon name="Settings" class="w-4 h-4 text-slate-400" />
        <h2 class="font-bold text-slate-800">Mapa de Slots</h2>
      </div>

      <div class="space-y-4">
        {(['head','body-end','post-schema','post-bottom','post-after'] as const).map(slot => {
          const inSlot = Object.entries(paths).filter(([, v]) => v.slots?.some((s: any) => s.slot === slot));
          return (
            <div>
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-bold text-violet-600 bg-violet-50 px-2 py-0.5 rounded font-mono">{slot}</span>
                <span class="text-xs text-slate-400">{slotLabels[slot]}</span>
              </div>
              {inSlot.length === 0 ? (
                <p class="text-xs text-slate-400 ml-2 italic">Nenhum plugin neste slot</p>
              ) : (
                <div class="ml-2 space-y-1.5">
                  {inSlot.map(([pname]) => {
                    const p = plugins.find(pl => pl.name === pname);
                    return (
                      <a
                        href={`/plugin/${pname}`}
                        class="flex items-center gap-3 p-2.5 rounded-xl bg-slate-50 hover:bg-violet-50 transition-colors group"
                      >
                        {p && (
                          <span class={`w-6 h-6 rounded-lg ${p.hub.bg} flex items-center justify-center shrink-0`}>
                            <Icon name={p.hub.icon} class={`w-3 h-3 ${p.hub.color}`} />
                          </span>
                        )}
                        <span class="text-sm font-medium text-slate-700 group-hover:text-violet-700">{p?.hub.label ?? pname}</span>
                        <Icon name="ChevronRight" class="w-3 h-3 text-slate-300 group-hover:text-violet-400 ml-auto" />
                      </a>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <!-- All paths table -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="p-6 border-b border-slate-100 flex items-center gap-2">
        <Icon name="FileText" class="w-4 h-4 text-slate-400" />
        <h2 class="font-bold text-slate-800">Mapeamento Completo de Arquivos</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="text-left px-5 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">Plugin</th>
              <th class="text-left px-5 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">Arquivo</th>
              <th class="text-left px-5 py-3 text-xs font-bold text-slate-500 uppercase tracking-wider">Destino no {theme.label}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {Object.entries(paths).flatMap(([pname, v]) => [
              ...v.files.map((f: any) => ({ plugin: pname, src: f.src, dest: f.dest, type: 'component' })),
              ...v.adminPages.map((f: any) => ({ plugin: pname, src: f.src, dest: f.dest, type: 'admin' })),
            ]).map(row => {
              const p = plugins.find(pl => pl.name === row.plugin);
              return (
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-5 py-3">
                    <a href={`/plugin/${row.plugin}`} class="flex items-center gap-2 hover:text-violet-600 transition-colors">
                      {p && <Icon name={p.hub.icon} class={`w-3.5 h-3.5 ${p.hub.color}`} />}
                      <span class="font-medium text-slate-700">{p?.hub.label ?? row.plugin}</span>
                    </a>
                  </td>
                  <td class="px-5 py-3">
                    <div class="flex items-center gap-2">
                      <span class={`text-[10px] font-bold px-1.5 py-0.5 rounded font-mono uppercase ${row.type === 'admin' ? 'bg-emerald-100 text-emerald-700' : 'bg-violet-100 text-violet-700'}`}>
                        {row.type === 'admin' ? 'admin' : row.src.split('.').pop()}
                      </span>
                      <code class="text-xs font-mono text-slate-600">{row.src}</code>
                    </div>
                  </td>
                  <td class="px-5 py-3">
                    <code class="text-xs font-mono text-slate-400">{row.dest}</code>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

  </div>
</DashLayout>
